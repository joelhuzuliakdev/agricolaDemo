---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ===== NAVBAR ===== -->
  <nav id="navbar">
    <a href="#" class="nav-logo">
      <div class="nav-logo-mark">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C8 2 4 6 4 10c0 5 8 12 8 12s8-7 8-12c0-4-4-8-8-8zm0 10.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 7.5 12 7.5s2.5 1.12 2.5 2.5S13.38 12.5 12 12.5z"></path>
        </svg>
      </div>
      <span class="nav-brand">Tierra Viva</span>
    </a>
    <ul class="nav-links" id="nav-links">
      <li><a href="#sobre">Nosotros</a></li>
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#cultivos">Cultivos</a></li>
      <li><a href="#galeria">Galería</a></li>
      <li><a href="#contacto" class="nav-cta">Contactar</a></li>
    </ul>
    <button class="nav-mobile-btn" id="mobile-btn" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-tag">Córdoba, Argentina — Desde 2003</div>
      <h1>Producción agrícola<br />de <em>calidad</em> y<br />compromiso con<br />la tierra</h1>
      <p class="hero-sub">Cultivamos el futuro del campo con tecnología de vanguardia, respeto por la naturaleza y décadas de experiencia en producción sostenible.</p>
      <div class="hero-btns">
        <a href="#sobre" class="btn-primary">Conocer más</a>
        <a href="#contacto" class="btn-secondary">Contactar</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat-item"><div class="stat-num">+20</div><div class="stat-label">Años de experiencia</div></div>
      <div class="stat-item"><div class="stat-num">15K</div><div class="stat-label">Hectáreas productivas</div></div>
      <div class="stat-item"><div class="stat-num">98%</div><div class="stat-label">Eficiencia de cosecha</div></div>
      <div class="stat-item"><div class="stat-num">100%</div><div class="stat-label">Producción sustentable</div></div>
    </div>
    <div class="hero-scroll-hint">
      <span>Desplazar</span>
      <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"></path></svg>
    </div>
  </section>

  <!-- ===== SOBRE NOSOTROS ===== -->
  <section class="about" id="sobre">
    <div class="about-inner">
      <div class="about-left reveal">
        <div class="section-tag">Nuestra historia</div>
        <h2 class="section-title">Más de dos décadas<br />trabajando la <em>tierra</em></h2>
        <div style="margin-top: 2rem;">
          <p>Tierra Viva nació con la convicción de que es posible producir alimentos de calidad sin comprometer el futuro del planeta. Desde nuestra fundación en 2003, hemos integrado tecnología de precisión con el conocimiento ancestral del campo argentino.</p>
          <p>Operamos en la provincia de Córdoba con un equipo de más de 120 profesionales apasionados por la tierra, comprometidos con la excelencia productiva y la sostenibilidad ambiental.</p>
        </div>
        <div class="about-features">
          <div class="about-feature reveal reveal-delay-1">
            <div class="feature-icon"><svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>
            <div class="feature-text"><h4>Certificación internacional</h4><p>Contamos con certificaciones GlobalG.A.P. y Rain Forest Alliance que garantizan nuestros estándares productivos.</p></div>
          </div>
          <div class="about-feature reveal reveal-delay-2">
            <div class="feature-icon"><svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"></path></svg></div>
            <div class="feature-text"><h4>Tecnología de precisión</h4><p>Utilizamos drones, sensores IoT y análisis de datos para optimizar cada decisión productiva en tiempo real.</p></div>
          </div>
          <div class="about-feature reveal reveal-delay-3">
            <div class="feature-icon"><svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z"></path></svg></div>
            <div class="feature-text"><h4>Compromiso ambiental</h4><p>Reducimos nuestra huella de carbono año a año con prácticas de agricultura regenerativa y manejo responsable del agua.</p></div>
          </div>
        </div>
      </div>
      <div class="about-image-wrap reveal reveal-delay-2">
        <img src="https://images.unsplash.com/photo-1625246333195-78d9c38ad449?w=900&q=80&auto=format&fit=crop" alt="Agricultores trabajando el campo" loading="lazy" />
        <div class="about-image-accent"></div>
        <div class="about-badge"><div class="about-badge-num">+20</div><div class="about-badge-text">años en el campo</div></div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICIOS ===== -->
  <section class="services" id="servicios">
    <div class="services-header reveal">
      <div>
        <div class="section-tag">Lo que hacemos</div>
        <h2 class="section-title">Nuestros<br /><em>servicios</em></h2>
      </div>
      <p>Ofrecemos soluciones integrales para el sector agropecuario, combinando experiencia, tecnología y respeto por el entorno natural.</p>
    </div>
    <div class="services-grid">
      <div class="service-card reveal reveal-delay-1">
        <div class="service-icon"><svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 01-4.4 2.26 5.403 5.403 0 01-3.14-9.8c-.1-.03-.2-.04-.3-.05-.13-.01-.27-.02-.4-.02"></path></svg></div>
        <h3>Producción de Cultivos</h3>
        <p>Gestión integral de siembra, seguimiento y cosecha de soja, maíz, trigo y girasol con tecnología de precisión y análisis de suelos permanente.</p>
        <div class="service-arrow">Ver más <svg viewBox="0 0 16 16" width="14" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"></path></svg></div>
      </div>
      <div class="service-card reveal reveal-delay-2">
        <div class="service-icon"><svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25V9m8.25 0H6.75m9 0v10.5A1.5 1.5 0 0114.25 21H9.75a1.5 1.5 0 01-1.5-1.5V9m7.5 0h1.5A1.5 1.5 0 0119.5 10.5v9A1.5 1.5 0 0118 21H6a1.5 1.5 0 01-1.5-1.5v-9A1.5 1.5 0 016 9h1.5"></path></svg></div>
        <h3>Ganadería Extensiva</h3>
        <p>Cría y engorde de ganado bovino bajo estándares de bienestar animal, con manejo rotacional de pasturas y sistemas de trazabilidad completa.</p>
        <div class="service-arrow">Ver más <svg viewBox="0 0 16 16" width="14" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"></path></svg></div>
      </div>
      <div class="service-card reveal reveal-delay-3">
        <div class="service-icon"><svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"></path></svg></div>
        <h3>Asesoramiento Agrícola</h3>
        <p>Consultoría técnica personalizada para productores independientes: planificación de campañas, análisis de suelos, gestión de plagas y optimización de rindes.</p>
        <div class="service-arrow">Ver más <svg viewBox="0 0 16 16" width="14" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"></path></svg></div>
      </div>
      <div class="service-card reveal reveal-delay-4">
        <div class="service-icon"><svg viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.893 13.393l-1.135-1.135a2.252 2.252 0 01-.421-.585l-1.08-2.16a.414.414 0 00-.663-.107.827.827 0 01-.812.21l-1.273-.363a.89.89 0 00-.738 1.595l.587.39c.59.395.674 1.23.172 1.732l-.2.2c-.212.212-.33.498-.33.796v.41c0 .409-.11.809-.32 1.158l-1.315 2.191a2.11 2.11 0 01-1.81 1.025 1.055 1.055 0 01-1.055-1.055v-1.172c0-.92-.56-1.747-1.414-2.089l-.655-.261a2.25 2.25 0 01-1.383-2.46l.007-.042a2.25 2.25 0 01.29-.787l.09-.15a2.25 2.25 0 012.37-1.048l1.178.236a1.125 1.125 0 001.302-.795l.208-.73a1.125 1.125 0 00-.578-1.315l-.665-.332-.091.091a2.25 2.25 0 01-1.591.659h-.18c-.249 0-.487.1-.662.274a.931.931 0 01-1.458-1.137l1.279-2.132z"></path></svg></div>
        <h3>Agricultura Sostenible</h3>
        <p>Implementación de prácticas regenerativas: labranza mínima, cultivos de cobertura, siembra directa y manejo integrado para preservar la salud del suelo.</p>
        <div class="service-arrow">Ver más <svg viewBox="0 0 16 16" width="14" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"></path></svg></div>
      </div>
    </div>
  </section>

  <!-- ===== CULTIVOS ===== -->
  <section class="crops" id="cultivos">
    <div class="crops-inner">
      <div class="crops-header reveal">
        <div class="section-tag">Lo que sembramos</div>
        <h2 class="section-title">Nuestros<br /><em>cultivos</em></h2>
        <p>Producimos los principales granos de la región pampeana con estándares de calidad internacional y seguimiento técnico permanente.</p>
      </div>
      <div class="crops-grid">
        <div class="crop-card reveal reveal-delay-1">
          <div class="crop-img-wrap">
            <img src="https://images.unsplash.com/photo-1574943320219-553eb213f72d?w=600&q=80&auto=format&fit=crop" alt="Soja" loading="lazy" />
            <div class="crop-badge">Leguminosa</div>
          </div>
          <div class="crop-body">
            <div class="crop-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 000 20M12 2c2 4 4 7 4 10a10 10 0 01-4 8M12 2C10 6 8 9 8 12a10 10 0 004 8"></path></svg></div>
            <h3>Soja</h3>
            <p>Principal cultivo de exportación. Sembramos variedades de alto rendimiento adaptadas al clima cordobés, con siembra directa para conservar el suelo.</p>
            <div class="crop-stats">
              <div><span>Hectáreas</span><strong>6.500 ha</strong></div>
              <div><span>Rendimiento</span><strong>4,2 tn/ha</strong></div>
            </div>
          </div>
        </div>
        <div class="crop-card reveal reveal-delay-2">
          <div class="crop-img-wrap">
            <img src="https://images.unsplash.com/photo-1601506521793-dc748fc80b67?w=600&q=80&auto=format&fit=crop" alt="Maíz" loading="lazy" />
            <div class="crop-badge">Cereal</div>
          </div>
          <div class="crop-body">
            <div class="crop-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M8 6c0 0 1 2 4 2s4-2 4-2M8 10c0 0 1 2 4 2s4-2 4-2M8 14c0 0 1 2 4 2s4-2 4-2"></path></svg></div>
            <h3>Maíz</h3>
            <p>Cultivo estratégico para rotación y nutrición del suelo. Utilizamos híbridos de última generación con monitoreo satelital de crecimiento.</p>
            <div class="crop-stats">
              <div><span>Hectáreas</span><strong>4.200 ha</strong></div>
              <div><span>Rendimiento</span><strong>10,5 tn/ha</strong></div>
            </div>
          </div>
        </div>
        <div class="crop-card reveal reveal-delay-3">
          <div class="crop-img-wrap">
            <img src="https://images.unsplash.com/photo-1535379453347-1ffd615e2e08?w=600&q=80&auto=format&fit=crop" alt="Trigo" loading="lazy" />
            <div class="crop-badge">Cereal</div>
          </div>
          <div class="crop-body">
            <div class="crop-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V8M8 14l4-4 4 4M8 18l4-4 4 4"></path><circle cx="12" cy="5" r="2"></circle></svg></div>
            <h3>Trigo</h3>
            <p>Cultivo de invierno fundamental para el esquema de doble cultivo. Producimos trigo pan de alta proteína para molinería nacional y exportación.</p>
            <div class="crop-stats">
              <div><span>Hectáreas</span><strong>2.800 ha</strong></div>
              <div><span>Rendimiento</span><strong>4,8 tn/ha</strong></div>
            </div>
          </div>
        </div>
        <div class="crop-card reveal reveal-delay-4">
          <div class="crop-img-wrap">
            <img src="https://images.unsplash.com/photo-1470509037663-253d1a1e8571?w=600&q=80&auto=format&fit=crop" alt="Girasol" loading="lazy" />
            <div class="crop-badge">Oleaginosa</div>
          </div>
          <div class="crop-body">
            <div class="crop-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"></path></svg></div>
            <h3>Girasol</h3>
            <p>Oleaginosa de alta adaptación al clima semiárido cordobés. Excelente opción de rotación que diversifica ingresos y mejora la estructura del suelo.</p>
            <div class="crop-stats">
              <div><span>Hectáreas</span><strong>1.500 ha</strong></div>
              <div><span>Rendimiento</span><strong>2,4 tn/ha</strong></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESO DE TRABAJO ===== -->
  <section class="process" id="proceso">
    <div class="process-inner">
      <div class="process-header reveal">
        <div class="section-tag">Cómo trabajamos</div>
        <h2 class="section-title">Nuestro<br /><em>proceso</em></h2>
        <p>Cada campaña se ejecuta siguiendo un protocolo riguroso que combina ciencia, experiencia y tecnología para maximizar resultados.</p>
      </div>
      <div class="process-steps">
        <div class="process-step reveal reveal-delay-1">
          <div class="step-number">01</div>
          <div class="step-connector"></div>
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1 1 .03 2.698-1.382 2.698H4.18c-1.412 0-2.38-1.698-1.381-2.698L4.2 15.3"></path></svg>
          </div>
          <div class="step-content">
            <h3>Análisis de suelo</h3>
            <p>Tomamos muestras georeferenciadas para evaluar nutrientes, pH y estructura. Con estos datos diseñamos el plan de fertilización exacto para cada lote.</p>
          </div>
        </div>
        <div class="process-step reveal reveal-delay-2">
          <div class="step-number">02</div>
          <div class="step-connector"></div>
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v2.25m0 0A9 9 0 0112 21M12 5.25A9 9 0 0021 12H3a9 9 0 009-6.75zM12 5.25V3"></path></svg>
          </div>
          <div class="step-content">
            <h3>Siembra de precisión</h3>
            <p>Utilizamos sembradoras con GPS de alta precisión para lograr densidades uniformes, profundidades controladas y distribución óptima de semilla.</p>
          </div>
        </div>
        <div class="process-step reveal reveal-delay-3">
          <div class="step-number">03</div>
          <div class="step-connector"></div>
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H6.911a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661z"></path></svg>
          </div>
          <div class="step-content">
            <h3>Monitoreo con tecnología</h3>
            <p>Drones multiespectrales, sensores IoT y plataformas de datos permiten detectar estrés hídrico, plagas y enfermedades antes de que afecten el rendimiento.</p>
          </div>
        </div>
        <div class="process-step reveal reveal-delay-4">
          <div class="step-number">04</div>
          <div class="step-connector last"></div>
          <div class="step-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"></path></svg>
          </div>
          <div class="step-content">
            <h3>Cosecha eficiente</h3>
            <p>Cosechadoras equipadas con sistemas de telemetría y rendímetros en tiempo real garantizan mínimas pérdidas y trazabilidad total de cada lote cosechado.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== IMPACTO ===== -->
  <section class="impact" id="impacto">
    <div class="impact-bg"></div>
    <div class="impact-overlay"></div>
    <div class="impact-inner">
      <div class="impact-header reveal">
        <div class="section-tag">Resultados concretos</div>
        <h2 class="section-title">Nuestro impacto<br />en el <em>campo</em></h2>
        <p>Dos décadas de trabajo sostenido se reflejan en números que hablan solos. Cada hectárea, cada tonelada, cada profesional: el resultado de un compromiso real con la tierra.</p>
      </div>
      <div class="impact-grid">
        <div class="impact-card reveal reveal-delay-1">
          <div class="impact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"></path></svg>
          </div>
          <div class="impact-num-wrap">
            <span class="impact-num" data-target="15000" data-suffix="+">0</span>
            <span class="impact-unit">ha</span>
          </div>
          <div class="impact-label">Hectáreas trabajadas</div>
          <div class="impact-bar"><div class="impact-bar-fill" style="--w: 100%"></div></div>
        </div>
        <div class="impact-card reveal reveal-delay-2">
          <div class="impact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div class="impact-num-wrap">
            <span class="impact-num" data-target="20" data-suffix="+">0</span>
            <span class="impact-unit">años</span>
          </div>
          <div class="impact-label">De experiencia</div>
          <div class="impact-bar"><div class="impact-bar-fill" style="--w: 20%"></div></div>
        </div>
        <div class="impact-card reveal reveal-delay-3">
          <div class="impact-icon">
