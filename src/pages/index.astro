<style>
  :root {
    --verde-oscuro: #1a2e1a; --verde-medio: #2d4a2d; --verde-oliva: #5c6e3a;
    --verde-claro: #8a9e5a; --verde-sage: #b5c49a; --beige: #f2ede4;
    --beige-oscuro: #e8dfd0; --crema: #faf8f3; --blanco: #ffffff;
    --texto-oscuro: #1a1a1a; --texto-medio: #4a4a4a;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: "DM Sans", sans-serif; color: var(--texto-oscuro); background: var(--crema); overflow-x: hidden; }
  h1, h2, h3, h4 { font-family: "Cormorant Garamond", serif; }

  /* NAVBAR */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 1.5rem 4rem; display: flex; justify-content: space-between; align-items: center; transition: all 0.4s ease; }
  nav.scrolled { background: rgba(26,46,26,0.97); backdrop-filter: blur(12px); padding: 1rem 4rem; box-shadow: 0 2px 40px rgba(0,0,0,0.3); }
  .nav-logo { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; }
  .nav-logo-mark { width: 38px; height: 38px; background: var(--verde-oliva); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .nav-logo-mark svg { width: 20px; height: 20px; fill: var(--beige); }
  .nav-brand { font-family: "Cormorant Garamond", serif; font-size: 1.5rem; font-weight: 500; color: var(--blanco); letter-spacing: 0.02em; }
  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a { color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.875rem; font-weight: 400; letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.3s; }
  .nav-links a:hover { color: var(--verde-sage); }
  .nav-cta { background: var(--verde-oliva); color: var(--blanco) !important; padding: 0.6rem 1.5rem; border-radius: 2px; }
  .nav-cta:hover { background: var(--verde-claro) !important; }
  .nav-mobile-btn { display: none; background: none; border: none; cursor: pointer; flex-direction: column; gap: 5px; padding: 4px; z-index: 110; }
  .nav-mobile-btn span { display: block; width: 24px; height: 2px; background: white; transition: all 0.3s; transform-origin: center; }
  .nav-mobile-btn.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-mobile-btn.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .nav-mobile-btn.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .nav-links.mobile-open { display: flex !important; flex-direction: column; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15,26,15,0.98); backdrop-filter: blur(16px); align-items: center; justify-content: center; gap: 2.5rem; z-index: 105; }
  .nav-links.mobile-open a { font-size: 1.4rem; letter-spacing: 0.1em; }
  .nav-links.mobile-open .nav-cta { padding: 0.8rem 2.5rem; font-size: 1rem; }

  /* HERO */
  .hero { position: relative; height: 100vh; min-height: 700px; display: flex; align-items: center; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background-image: url("https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1920&q=85&auto=format&fit=crop"); background-size: cover; background-position: center 40%; animation: heroZoom 12s ease-out forwards; }
  @keyframes heroZoom { from { transform: scale(1.08); } to { transform: scale(1); } }
  .hero-overlay { position: absolute; inset: 0; background: linear-gradient(135deg, rgba(15,28,15,0.78) 0%, rgba(26,46,26,0.55) 50%, rgba(40,60,20,0.35) 100%); }
  .hero-content { position: relative; z-index: 2; max-width: 860px; padding: 0 4rem; margin-top: 5rem; opacity: 0; animation: heroFadeUp 1.2s ease 0.3s forwards; }
  @keyframes heroFadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .hero-tag { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.1); border: 1px solid rgba(181,196,154,0.4); color: var(--verde-sage); font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.4rem 1rem; border-radius: 2px; margin-bottom: 1.75rem; }
  .hero-tag::before { content: ""; width: 18px; height: 1px; background: var(--verde-sage); }
  .hero h1 { font-size: clamp(2.4rem, 5.5vw, 5.5rem); font-weight: 300; line-height: 1.08; color: var(--blanco); letter-spacing: -0.01em; margin-bottom: 1.5rem; }
  .hero h1 em { font-style: italic; color: var(--verde-sage); }
  .hero-sub { font-size: 1.05rem; color: rgba(255,255,255,0.75); font-weight: 300; line-height: 1.7; max-width: 520px; margin-bottom: 2.5rem; }
  .hero-btns { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-primary { background: var(--verde-oliva); color: var(--blanco); padding: 0.9rem 2.2rem; border-radius: 2px; text-decoration: none; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; transition: all 0.3s; border: 1px solid var(--verde-oliva); }
  .btn-primary:hover { background: var(--verde-claro); border-color: var(--verde-claro); transform: translateY(-1px); }
  .btn-secondary { background: transparent; color: var(--blanco); padding: 0.9rem 2.2rem; border-radius: 2px; text-decoration: none; font-size: 0.875rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.4); transition: all 0.3s; }
  .btn-secondary:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.7); transform: translateY(-1px); }
  .hero-scroll-hint { position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: rgba(255,255,255,0.5); font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; z-index: 2; animation: bounce 2.5s ease-in-out infinite; }
  @keyframes bounce { 0%, 100% { transform: translateX(-50%) translateY(0); } 50% { transform: translateX(-50%) translateY(6px); } }
  .hero-scroll-hint svg { width: 16px; height: 16px; stroke: rgba(255,255,255,0.5); }
  .hero-stats { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(26,46,26,0.92); backdrop-filter: blur(8px); display: grid; grid-template-columns: repeat(4, 1fr); z-index: 2; }
  .stat-item { padding: 1.5rem 2rem; text-align: center; border-right: 1px solid rgba(255,255,255,0.08); }
  .stat-item:last-child { border-right: none; }
  .stat-num { font-family: "Cormorant Garamond", serif; font-size: 2.2rem; font-weight: 500; color: var(--verde-sage); line-height: 1; }
  .stat-label { font-size: 0.72rem; color: rgba(255,255,255,0.55); letter-spacing: 0.08em; text-transform: uppercase; margin-top: 0.3rem; }

  /* GENERAL */
  section { padding: 7rem 4rem; }
  .section-tag { display: inline-flex; align-items: center; gap: 0.75rem; font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--verde-oliva); font-weight: 500; margin-bottom: 1.25rem; }
  .section-tag::before { content: ""; width: 32px; height: 1px; background: var(--verde-oliva); }
  .section-title { font-size: clamp(2rem, 3.5vw, 3.5rem); font-weight: 300; line-height: 1.15; color: var(--verde-oscuro); letter-spacing: -0.01em; }
  .section-title em { font-style: italic; color: var(--verde-oliva); }

  /* SOBRE */
  .about { background: var(--crema); padding: 7rem 4rem; }
  .about-inner { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center; }
  .about-left p { color: var(--texto-medio); line-height: 1.85; font-size: 1rem; font-weight: 300; margin-bottom: 1.25rem; }
  .about-features { margin-top: 2.5rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .about-feature { display: flex; align-items: flex-start; gap: 1rem; padding-bottom: 1.25rem; border-bottom: 1px solid var(--beige-oscuro); }
  .about-feature:last-child { border-bottom: none; }
  .feature-icon { width: 40px; height: 40px; background: var(--verde-oscuro); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .feature-icon svg { width: 18px; height: 18px; stroke: var(--verde-sage); fill: none; }
  .feature-text h4 { font-family: "Cormorant Garamond", serif; font-size: 1.15rem; font-weight: 500; color: var(--verde-oscuro); margin-bottom: 0.25rem; }
  .feature-text p { font-size: 0.875rem; color: var(--texto-medio); line-height: 1.6; margin: 0; }
  .about-image-wrap { position: relative; }
  .about-image-wrap img { width: 100%; height: 580px; object-fit: cover; border-radius: 4px; }
  .about-image-accent { position: absolute; bottom: -2rem; left: -2rem; width: 180px; height: 180px; background: var(--verde-oliva); border-radius: 4px; z-index: -1; }
  .about-badge { position: absolute; top: 2rem; right: -2rem; background: var(--verde-oscuro); color: var(--blanco); padding: 1.5rem; border-radius: 4px; text-align: center; z-index: 2; }
  .about-badge-num { font-family: "Cormorant Garamond", serif; font-size: 3rem; font-weight: 500; color: var(--verde-sage); line-height: 1; }
  .about-badge-text { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.7); margin-top: 0.3rem; }

  /* SERVICIOS */
  .services { background: var(--verde-oscuro); padding: 7rem 4rem; }
  .services-header { max-width: 1280px; margin: 0 auto 4rem; display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem; }
  .services-header .section-title { color: var(--beige); }
  .services-header .section-title em { color: var(--verde-sage); }
  .services-header .section-tag { color: var(--verde-sage); }
  .services-header .section-tag::before { background: var(--verde-sage); }
  .services-header p { max-width: 340px; color: rgba(255,255,255,0.55); font-size: 0.9rem; line-height: 1.75; font-weight: 300; }
  .services-grid { max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .service-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 4px; padding: 2.5rem 2rem; transition: all 0.4s ease; cursor: default; position: relative; overflow: hidden; }
  .service-card::before { content: ""; position: absolute; bottom: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--verde-oliva), var(--verde-claro)); transform: scaleX(0); transition: transform 0.4s ease; }
  .service-card:hover { background: rgba(255,255,255,0.08); border-color: rgba(181,196,154,0.25); transform: translateY(-4px); box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
  .service-card:hover::before { transform: scaleX(1); }
  .service-icon { width: 52px; height: 52px; background: rgba(181,196,154,0.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.75rem; }
  .service-icon svg { width: 24px; height: 24px; stroke: var(--verde-sage); fill: none; }
  .service-card h3 { font-size: 1.4rem; font-weight: 400; color: var(--beige); margin-bottom: 0.85rem; }
  .service-card p { font-size: 0.875rem; color: rgba(255,255,255,0.5); line-height: 1.75; font-weight: 300; }
  .service-arrow { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.5rem; color: var(--verde-sage); font-size: 0.8rem; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0; transition: opacity 0.3s; }
  .service-arrow svg { stroke: var(--verde-sage); fill: none; }
  .service-card:hover .service-arrow { opacity: 1; }

  /* CULTIVOS */
  .crops { background: var(--beige); padding: 7rem 4rem; }
  .crops-inner { max-width: 1280px; margin: 0 auto; }
  .crops-header { text-align: center; margin-bottom: 4rem; }
  .crops-header .section-tag { justify-content: center; }
  .crops-header p { max-width: 560px; margin: 1rem auto 0; color: var(--texto-medio); font-size: 0.95rem; line-height: 1.75; font-weight: 300; }
  .crops-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .crop-card { background: var(--crema); border-radius: 4px; overflow: hidden; border: 1px solid var(--beige-oscuro); transition: all 0.4s ease; }
  .crop-card:hover { transform: translateY(-6px); box-shadow: 0 24px 60px rgba(26,46,26,0.12); border-color: var(--verde-sage); }
  .crop-img-wrap { position: relative; height: 200px; overflow: hidden; }
  .crop-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease; display: block; }
  .crop-card:hover .crop-img-wrap img { transform: scale(1.07); }
  .crop-badge { position: absolute; top: 1rem; left: 1rem; background: var(--verde-oscuro); color: var(--verde-sage); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.3rem 0.75rem; border-radius: 2px; }
  .crop-body { padding: 1.75rem; }
  .crop-icon { width: 40px; height: 40px; background: var(--verde-oscuro); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
  .crop-icon svg { width: 18px; height: 18px; stroke: var(--verde-sage); fill: none; }
  .crop-body h3 { font-size: 1.5rem; font-weight: 400; color: var(--verde-oscuro); margin-bottom: 0.6rem; }
  .crop-body p { font-size: 0.85rem; color: var(--texto-medio); line-height: 1.7; font-weight: 300; margin-bottom: 1.25rem; }
  .crop-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; padding-top: 1.25rem; border-top: 1px solid var(--beige-oscuro); }
  .crop-stats div span { display: block; font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--verde-oliva); margin-bottom: 0.2rem; }
  .crop-stats div strong { font-family: "Cormorant Garamond", serif; font-size: 1.2rem; color: var(--verde-oscuro); font-weight: 500; }

  /* PROCESO */
  .process { background: var(--verde-oscuro); padding: 7rem 4rem; }
  .process-inner { max-width: 1280px; margin: 0 auto; }
  .process-header { max-width: 600px; margin: 0 auto 5rem; text-align: center; }
  .process-header .section-tag { justify-content: center; color: var(--verde-sage); }
  .process-header .section-tag::before { background: var(--verde-sage); }
  .process-header .section-title { color: var(--beige); }
  .process-header .section-title em { color: var(--verde-sage); }
  .process-header p { margin-top: 1rem; color: rgba(255,255,255,0.5); font-size: 0.95rem; line-height: 1.75; font-weight: 300; }
  .process-steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; }
  .process-step { position: relative; padding: 0 1.5rem; }
  .step-number { font-family: "Cormorant Garamond", serif; font-size: 4rem; font-weight: 300; color: rgba(181,196,154,0.15); line-height: 1; margin-bottom: -0.75rem; }
  .step-connector { position: absolute; top: 5rem; left: calc(50% + 2.5rem); right: -50%; height: 1px; background: rgba(181,196,154,0.2); }
  .step-connector.last { display: none; }
  .step-icon { width: 64px; height: 64px; background: rgba(181,196,154,0.1); border: 1px solid rgba(181,196,154,0.25); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem; position: relative; z-index: 1; transition: all 0.3s; }
  .process-step:hover .step-icon { background: var(--verde-oliva); border-color: var(--verde-oliva); }
  .step-icon svg { width: 28px; height: 28px; stroke: var(--verde-sage); fill: none; }
  .step-content h3 { font-size: 1.3rem; font-weight: 400; color: var(--beige); margin-bottom: 0.75rem; }
  .step-content p { font-size: 0.875rem; color: rgba(255,255,255,0.5); line-height: 1.75; font-weight: 300; }

  /* BANNER */
  .banner { position: relative; height: 520px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .banner-bg { position: absolute; inset: 0; background-image: url("https://images.unsplash.com/photo-1574943320219-553eb213f72d?w=1920&q=80&auto=format&fit=crop"); background-size: cover; background-position: center; background-attachment: fixed; }
  .banner-overlay { position: absolute; inset: 0; background: rgba(15,30,10,0.68); }
  .banner-content { position: relative; z-index: 2; text-align: center; max-width: 820px; padding: 0 2rem; }
  .banner-content .section-tag { justify-content: center; color: var(--verde-sage); }
  .banner-content .section-tag::before { background: var(--verde-sage); }
  .banner-content h2 { font-size: clamp(1.8rem, 4vw, 4rem); font-weight: 300; color: var(--blanco); line-height: 1.25; }
  .banner-content h2 em { color: var(--verde-sage); }

  /* GALERÍA */
  .gallery { background: var(--crema); padding: 7rem 4rem; }
  .gallery-inner { max-width: 1280px; margin: 0 auto; }
  .gallery-header { margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem; flex-wrap: wrap; }
  .gallery-header p { max-width: 300px; font-size: 0.9rem; color: var(--texto-medio); line-height: 1.7; font-weight: 300; }
  .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .gallery-item { overflow: hidden; border-radius: 4px; position: relative; cursor: pointer; }
  .gallery-item:nth-child(1) { grid-row: span 2; }
  .gallery-item:nth-child(4) { grid-column: span 2; }
  .gallery-item img { width: 100%; height: 100%; min-height: 240px; object-fit: cover; transition: transform 0.6s ease; display: block; }
  .gallery-item:hover img { transform: scale(1.06); }
  .gallery-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(20,40,20,0.7) 0%, transparent 60%); opacity: 0; transition: opacity 0.4s ease; display: flex; align-items: flex-end; padding: 1.5rem; }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-overlay-text { color: var(--blanco); font-size: 0.85rem; font-weight: 400; letter-spacing: 0.04em; }

  /* CERTIFICACIONES */
  .certs { background: var(--crema); padding: 7rem 4rem; border-top: 1px solid var(--beige-oscuro); }
  .certs-inner { max-width: 1280px; margin: 0 auto; }
  .certs-header { text-align: center; margin-bottom: 4rem; }
  .certs-header .section-tag { justify-content: center; }
  .certs-header p { max-width: 600px; margin: 1rem auto 0; color: var(--texto-medio); font-size: 0.95rem; line-height: 1.8; font-weight: 300; }
  .certs-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
